// Example layout for development/testing
layout {
    pane size=1 borderless=true {
        plugin location="zellij:tab-bar"
    }

    pane split_direction="vertical" {
        pane size="50%" command="zsh" name="Shell"

        pane size="50%" name="Monitor" {
            plugin location="file:target/wasm32-wasip1/release/zellij-claude-monitor.wasm" {
                // claude_dir "$HOME/.claude"
                plan "max5"
            }
        }
    }

    pane size=1 borderless=true {
        plugin location="zellij:status-bar"
    }
}
