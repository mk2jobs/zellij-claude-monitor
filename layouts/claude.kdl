layout {
    tab_template name="ui" {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
    }

    // 기본 레이아웃: 우측 패널 (RIGHT PANEL)
    ui {
        pane split_direction="vertical" {
            pane size="65%" command="claude-session" name="Claude Code"
            pane {
                pane size="70%" name="Monitor" {
                    plugin location="file:~/.config/zellij/plugins/zellij-claude-monitor.wasm" {
                        plan "max5"
                    }
                }
                pane size="30%" name="Files" {
                    plugin location="zellij:strider"
                }
            }
        }
    }

    // Alt [ / Alt ] 로 전환: RIGHT → BOTTOM → NONE 순환
    swap_tiled_layout name="BOTTOM PANEL" {
        ui max_panes=4 {
            pane {
                pane size="65%"
                pane split_direction="vertical" {
                    pane size="70%"
                    pane size="30%"
                }
            }
        }
    }

    swap_tiled_layout name="FOCUS" {
        ui max_panes=4 {
            pane stacked=true { pane; pane; pane; }
        }
    }
}
