layout {
    tab_template name="ui" {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
    }

    // 기본 레이아웃: NONE (all stacked) — Claude Code가 포커스
    ui {
        pane stacked=true {
            pane command="claude-session" name="Claude Code" focus=true
            pane name="Monitor" {
                plugin location="file:~/.config/zellij/plugins/zellij-claude-monitor.wasm" {
                    plan "max5"
                    // claude_dir "/home/youruser/.claude"  // optional: override auto-detected ~/.claude path
                    _allow_exec_host_cmd true
                }
            }
            pane name="Files" {
                plugin location="zellij:strider"
            }
        }
    }

    // Alt [ / Alt ] 로 전환: NONE → RIGHT → BOTTOM → NONE 순환
    swap_tiled_layout name="RIGHT PANEL" {
        ui max_panes=4 {
            pane split_direction="vertical" {
                pane size="65%"
                pane {
                    pane size="70%"
                    pane size="30%"
                }
            }
        }
    }

    swap_tiled_layout name="BOTTOM PANEL" {
        ui max_panes=4 {
            pane {
                pane size="65%"
                pane split_direction="vertical" {
                    pane size="70%"
                    pane size="30%"
                }
            }
        }
    }
}
